<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="CampLedger.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:CampLedger.Pages"
    Title="CampLedger"
    FlyoutBehavior="Locked"
    SizeChanged="OnShellSizeChanged"
    Shell.NavBarHasShadow="True"
    Shell.FlyoutBackgroundColor="{DynamicResource SurfaceColor}"
    Shell.ForegroundColor="{DynamicResource PrimaryTextColor}">

    <Shell.TitleView>
        <Grid Padding="0,0,16,0" VerticalOptions="Center">
            <Label
                FontAttributes="Bold"
                FontSize="18"
                Text="CampLedger"
                TextColor="{DynamicResource PrimaryTextColor}"
                VerticalOptions="Center" />
        </Grid>
    </Shell.TitleView>

    <Shell.ItemTemplate>
        <DataTemplate>
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12" Padding="16,10" HeightRequest="48" VerticalOptions="Center">
                <Image Grid.Column="0"
                       Source="{Binding FlyoutIcon}"
                       HeightRequest="18"
                       WidthRequest="18"
                       Aspect="AspectFit"
                       VerticalOptions="Center"
                       HorizontalOptions="Center" />
                <Label Grid.Column="1"
                       Text="{Binding Title}"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="{DynamicResource PrimaryTextColor}"
                       VerticalOptions="Center"
                       LineBreakMode="TailTruncation" />
            </Grid>
        </DataTemplate>
    </Shell.ItemTemplate>

    <FlyoutItem FlyoutDisplayOptions="AsMultipleItems" Route="MainMenu" Shell.TabBarIsVisible="False">
        <ShellContent Route="InventoryPage" Title="Inventory" ContentTemplate="{DataTemplate pages:InventoryPage}">
            <ShellContent.Icon>
                <FontImageSource FontFamily="Segoe Fluent Icons" Glyph="&#xe7F8;" Size="18" Color="{DynamicResource PrimaryColor}" />
            </ShellContent.Icon>
        </ShellContent>

        <ShellContent Route="TripLedgerPage" Title="Trip Ledger" ContentTemplate="{DataTemplate pages:TripLedgerPage}">
            <ShellContent.Icon>
                <FontImageSource FontFamily="Segoe Fluent Icons" Glyph="&#xe787;" Size="18" Color="{DynamicResource PrimaryColor}" />
            </ShellContent.Icon>
        </ShellContent>

        <ShellContent Route="TripHistoryPage" Title="History" ContentTemplate="{DataTemplate pages:TripHistoryPage}">
            <ShellContent.Icon>
                <FontImageSource FontFamily="Segoe Fluent Icons" Glyph="&#xe81c;" Size="18" Color="{DynamicResource PrimaryColor}" />
            </ShellContent.Icon>
        </ShellContent>
    </FlyoutItem>

    <Shell.FlyoutFooter>
        <Grid Padding="16,14" BackgroundColor="{DynamicResource SurfaceAltColor}" HeightRequest="56" VerticalOptions="End">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnThemeGearTapped" />
            </Grid.GestureRecognizers>

            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" VerticalOptions="Center">
                <Label Grid.Column="0"
                       FontFamily="Segoe Fluent Icons"
                       FontSize="18"
                       Text="&#xE713;"
                       TextColor="{DynamicResource PrimaryTextColor}"
                       VerticalOptions="Center" />
                <Label Grid.Column="1"
                       FontAttributes="Bold"
                       FontSize="14"
                       Text="Theme"
                       TextColor="{DynamicResource PrimaryTextColor}"
                       VerticalOptions="Center"
                       LineBreakMode="TailTruncation" />
            </Grid>
        </Grid>
    </Shell.FlyoutFooter>

</Shell>
