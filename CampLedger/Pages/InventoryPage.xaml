<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:CampLedger.ViewModels"
             x:Class="CampLedger.Pages.InventoryPage"
             x:DataType="viewModels:InventoryViewModel"
             Title="Inventory"
             Style="{StaticResource PageStyle}">

    <Grid RowDefinitions="Auto,*" Padding="16" RowSpacing="16">
        <Border Padding="12"
                BackgroundColor="{DynamicResource SurfaceColor}"
                Stroke="{DynamicResource BorderColor}"
                StrokeShape="RoundRectangle 16">
            <VerticalStackLayout Spacing="8">
                <Label Text="Search inventory" FontAttributes="Bold" FontSize="18" />
                <SearchBar x:Name="SearchBar"
                           Placeholder="Search all items..."
                           SearchCommand="{Binding SearchCommand}"
                           SearchCommandParameter="{Binding Text, Source={x:Reference SearchBar}}"
                           TextChanged="OnSearchTextChanged" />
                <Button Clicked="OnClearSearchClicked" ImageSource="{FontImageSource Glyph={StaticResource IconClear}, FontFamily={StaticResource IconFontFamily}, Size=20}" SemanticProperties.Description="Clear search" />
            </VerticalStackLayout>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="16">
                <Border Padding="12"
                        BackgroundColor="{DynamicResource SurfaceColor}"
                        Stroke="{DynamicResource BorderColor}"
                        StrokeThickness="2"
                        StrokeShape="RoundRectangle 16">
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding IsNeedsDragSource}" Value="True">
                            <Setter Property="BackgroundColor" Value="#EEF2FF" />
                            <Setter Property="Stroke" Value="#4F46E5" />
                        </DataTrigger>
                    </Border.Triggers>
                    <Border.GestureRecognizers>
                        <DropGestureRecognizer AllowDrop="True"
                                               DragOver="OnNeedsDropZoneDragOver"
                                               DragLeave="OnDropZoneDragLeave"
                                               Drop="OnNeedsDropZoneDrop" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <Label Text="Needs" FontAttributes="Bold" FontSize="20"
                                   TextColor="{DynamicResource PrimaryColor}" VerticalOptions="Center" />
                            <Button Grid.Column="1" IsVisible="{Binding IsNeedsToggleVisible}" ImageSource="{FontImageSource Glyph={StaticResource IconExpand}, FontFamily={StaticResource IconFontFamily}, Size=20}" SemanticProperties.Description="Expand or collapse Needs"
                                    Command="{Binding ToggleNeedsExpandedCommand}"
                                    MinimumWidthRequest="44">
                                <Button.Triggers>
                                    <DataTrigger TargetType="Button" Binding="{Binding IsNeedsExpanded}" Value="True">
                                       <Setter Property="ImageSource" Value="{FontImageSource Glyph={StaticResource IconCollapse}, FontFamily={StaticResource IconFontFamily}, Size=20}" />
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button>
                        </Grid>
                        <VerticalStackLayout IsVisible="{Binding IsNeedsExpanded}" Spacing="10">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <Entry Grid.Column="0" Placeholder="Add a needed item" Text="{Binding NewNeedsItemName}" ReturnCommand="{Binding AddNeedsItemCommand}"/>
                                <Button Grid.Column="1" ImageSource="{FontImageSource Glyph={StaticResource IconAdd}, FontFamily={StaticResource IconFontFamily}, Size=20}" SemanticProperties.Description="Add item" Command="{Binding AddNeedsItemCommand}" />
                            </Grid>
                            <CollectionView ItemsSource="{Binding NeedsItems}" SelectionMode="None"
                                            ItemSizingStrategy="MeasureFirstItem">
                                <CollectionView.ItemsLayout>
                                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="8" />
                                </CollectionView.ItemsLayout>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="viewModels:InventoryItemViewModel">
                                        <Border Padding="10"
                                                BackgroundColor="{DynamicResource SurfaceAltColor}"
                                                Stroke="{DynamicResource BorderColor}"
                                                StrokeShape="RoundRectangle 12">
                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border" Binding="{Binding IsBeingDragged}" Value="True">
                                                    <Setter Property="BackgroundColor" Value="#EEF2FF" />
                                                    <Setter Property="Stroke" Value="#4F46E5" />
                                                    <Setter Property="StrokeThickness" Value="2" />
                                                </DataTrigger>
                                            </Border.Triggers>
                                            <Border.GestureRecognizers>
                                                <DragGestureRecognizer DragStarting="OnItemDragStarting"
                                                                       DropCompleted="OnItemDropCompleted" />
                                            </Border.GestureRecognizers>
                                            <VerticalStackLayout Spacing="8">
                                                <Label Text="{Binding Name}" FontAttributes="Bold" LineBreakMode="WordWrap" />
                                                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                                    <Button ImageSource="{FontImageSource Glyph={StaticResource IconEdit}, FontFamily={StaticResource IconFontFamily}, Size=20}" SemanticProperties.Description="Edit item" Clicked="OnEditItemClicked" />
                                                    <Button Grid.Column="1" ImageSource="{FontImageSource Glyph={StaticResource IconCamera}, FontFamily={StaticResource IconFontFamily}, Size=20}" SemanticProperties.Description="Add photo" Clicked="OnAddPhotoClicked" />
                                                </Grid>
                                                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                                    <Button Text="Preview" Clicked="OnPhotoPreviewClicked" IsVisible="{Binding HasPhoto}" />
                                                    <Button Grid.Column="1" ImageSource="{FontImageSource Glyph={StaticResource IconRemove}, FontFamily={StaticResource IconFontFamily}, Size=20}" SemanticProperties.Description="Remove item" Clicked="OnRemoveItemClicked"
                                                            BackgroundColor="{DynamicResource ErrorColor}" />
                                                </Grid>
                                            </VerticalStackLayout>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Border Padding="12"
                        BackgroundColor="{DynamicResource SurfaceColor}"
                        Stroke="{DynamicResource BorderColor}"
                        StrokeThickness="2"
                        StrokeShape="RoundRectangle 16">
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding IsWantsDragSource}" Value="True">
                            <Setter Property="BackgroundColor" Value="#EEF2FF" />
                            <Setter Property="Stroke" Value="#4F46E5" />
                        </DataTrigger>
                    </Border.Triggers>
                    <Border.GestureRecognizers>
                        <DropGestureRecognizer AllowDrop="True"
                                               DragOver="OnWantsDropZoneDragOver"
                                               DragLeave="OnDropZoneDragLeave"
                                               Drop="OnWantsDropZoneDrop" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <Label Text="Wants" FontAttributes="Bold" FontSize="20"
                                   TextColor="{DynamicResource PrimaryColor}" VerticalOptions="Center" />
                            <Button Grid.Column="1" IsVisible="{Binding IsWantsToggleVisible}" ImageSource="{FontImageSource Glyph={StaticResource IconExpand}, FontFamily={StaticResource IconFontFamily}, Size=20}" SemanticProperties.Description="Expand or collapse Wants"
                                    Command="{Binding ToggleWantsExpandedCommand}"
                                    MinimumWidthRequest="44">
                                <Button.Triggers>
                                    <DataTrigger TargetType="Button" Binding="{Binding IsWantsExpanded}" Value="True">
                                       <Setter Property="ImageSource" Value="{FontImageSource Glyph={StaticResource IconCollapse}, FontFamily={StaticResource IconFontFamily}, Size=20}" />
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button>
                        </Grid>
                        <VerticalStackLayout IsVisible="{Binding IsWantsExpanded}" Spacing="10">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <Entry Grid.Column="0" Placeholder="Add an optional item" Text="{Binding NewWantsItemName}" ReturnCommand="{Binding AddWantsItemCommand}" />
                                <Button Grid.Column="1" ImageSource="{FontImageSource Glyph={StaticResource IconAdd}, FontFamily={StaticResource IconFontFamily}, Size=20}" SemanticProperties.Description="Add item" Command="{Binding AddWantsItemCommand}" />
                            </Grid>
                            <CollectionView ItemsSource="{Binding WantsItems}" SelectionMode="None"
                                            ItemSizingStrategy="MeasureFirstItem">
                                <CollectionView.ItemsLayout>
                                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="8" />
                                </CollectionView.ItemsLayout>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="viewModels:InventoryItemViewModel">
                                        <Border Padding="10"
                                                BackgroundColor="{DynamicResource SurfaceAltColor}"
                                                Stroke="{DynamicResource BorderColor}"
                                                StrokeShape="RoundRectangle 12">
                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border" Binding="{Binding IsBeingDragged}" Value="True">
                                                    <Setter Property="BackgroundColor" Value="#EEF2FF" />
                                                    <Setter Property="Stroke" Value="#4F46E5" />
                                                    <Setter Property="StrokeThickness" Value="2" />
                                                </DataTrigger>
                                            </Border.Triggers>
                                            <Border.GestureRecognizers>
                                                <DragGestureRecognizer DragStarting="OnItemDragStarting"
                                                                       DropCompleted="OnItemDropCompleted" />
                                            </Border.GestureRecognizers>
                                            <VerticalStackLayout Spacing="8">
                                                <Label Text="{Binding Name}" FontAttributes="Bold" LineBreakMode="WordWrap" />
                                                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                                    <Button ImageSource="{FontImageSource Glyph={StaticResource IconEdit}, FontFamily={StaticResource IconFontFamily}, Size=20}" SemanticProperties.Description="Edit item" Clicked="OnEditItemClicked" />
                                                    <Button Grid.Column="1" ImageSource="{FontImageSource Glyph={StaticResource IconCamera}, FontFamily={StaticResource IconFontFamily}, Size=20}" SemanticProperties.Description="Add photo" Clicked="OnAddPhotoClicked" />
                                                </Grid>
                                                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                                    <Button Text="Preview" Clicked="OnPhotoPreviewClicked" IsVisible="{Binding HasPhoto}" />
                                                    <Button Grid.Column="1" ImageSource="{FontImageSource Glyph={StaticResource IconRemove}, FontFamily={StaticResource IconFontFamily}, Size=20}" SemanticProperties.Description="Remove item" Clicked="OnRemoveItemClicked"
                                                            BackgroundColor="{DynamicResource ErrorColor}" />
                                                </Grid>
                                            </VerticalStackLayout>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Border Padding="12"
                        BackgroundColor="{DynamicResource SurfaceColor}"
                        Stroke="{DynamicResource BorderColor}"
                        StrokeThickness="2"
                        StrokeShape="RoundRectangle 16">
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding IsHasDragSource}" Value="True">
                            <Setter Property="BackgroundColor" Value="#EEF2FF" />
                            <Setter Property="Stroke" Value="#4F46E5" />
                        </DataTrigger>
                    </Border.Triggers>
                    <Border.GestureRecognizers>
                        <DropGestureRecognizer AllowDrop="True"
                                               DragOver="OnHasDropZoneDragOver"
                                               DragLeave="OnDropZoneDragLeave"
                                               Drop="OnHasDropZoneDrop" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <Label Text="Has" FontAttributes="Bold" FontSize="20"
                                   TextColor="{DynamicResource PrimaryColor}" VerticalOptions="Center" />
                            <Button Grid.Column="1" IsVisible="{Binding IsHasToggleVisible}" ImageSource="{FontImageSource Glyph={StaticResource IconExpand}, FontFamily={StaticResource IconFontFamily}, Size=20}" SemanticProperties.Description="Expand or collapse Has"
                                    Command="{Binding ToggleHasExpandedCommand}"
                                    MinimumWidthRequest="44">
                                <Button.Triggers>
                                    <DataTrigger TargetType="Button" Binding="{Binding IsHasExpanded}" Value="True">
                                       <Setter Property="ImageSource" Value="{FontImageSource Glyph={StaticResource IconCollapse}, FontFamily={StaticResource IconFontFamily}, Size=20}" />
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button>
                        </Grid>
                        <VerticalStackLayout IsVisible="{Binding IsHasExpanded}" Spacing="10">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <Entry Grid.Column="0" Placeholder="Add an owned item" Text="{Binding NewHasItemName}" ReturnCommand="{Binding AddHasItemCommand}"/>
                                <Button Grid.Column="1" ImageSource="{FontImageSource Glyph={StaticResource IconAdd}, FontFamily={StaticResource IconFontFamily}, Size=20}" SemanticProperties.Description="Add item" Command="{Binding AddHasItemCommand}" />
                            </Grid>
                            <CollectionView ItemsSource="{Binding HasItems}" SelectionMode="None"
                                            ItemSizingStrategy="MeasureFirstItem">
                                <CollectionView.ItemsLayout>
                                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="8" />
                                </CollectionView.ItemsLayout>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="viewModels:InventoryItemViewModel">
                                        <Border Padding="10"
                                                BackgroundColor="{DynamicResource SurfaceAltColor}"
                                                Stroke="{DynamicResource BorderColor}"
                                                StrokeShape="RoundRectangle 12">
                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border" Binding="{Binding IsBeingDragged}" Value="True">
                                                    <Setter Property="BackgroundColor" Value="#EEF2FF" />
                                                    <Setter Property="Stroke" Value="#4F46E5" />
                                                    <Setter Property="StrokeThickness" Value="2" />
                                                </DataTrigger>
                                            </Border.Triggers>
                                            <Border.GestureRecognizers>
                                                <DragGestureRecognizer DragStarting="OnItemDragStarting"
                                                                       DropCompleted="OnItemDropCompleted" />
                                            </Border.GestureRecognizers>
                                            <VerticalStackLayout Spacing="8">
                                                <Label Text="{Binding Name}" FontAttributes="Bold" LineBreakMode="WordWrap" />
                                                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                                    <Button ImageSource="{FontImageSource Glyph={StaticResource IconEdit}, FontFamily={StaticResource IconFontFamily}, Size=20}" SemanticProperties.Description="Edit item" Clicked="OnEditItemClicked" />
                                                    <Button Grid.Column="1" ImageSource="{FontImageSource Glyph={StaticResource IconCamera}, FontFamily={StaticResource IconFontFamily}, Size=20}" SemanticProperties.Description="Add photo" Clicked="OnAddPhotoClicked" />
                                                </Grid>
                                                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                                    <Button Text="Preview" Clicked="OnPhotoPreviewClicked" IsVisible="{Binding HasPhoto}" />
                                                    <Button Grid.Column="1" ImageSource="{FontImageSource Glyph={StaticResource IconRemove}, FontFamily={StaticResource IconFontFamily}, Size=20}" SemanticProperties.Description="Remove item" Clicked="OnRemoveItemClicked"
                                                            BackgroundColor="{DynamicResource ErrorColor}" />
                                                </Grid>
                                            </VerticalStackLayout>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
