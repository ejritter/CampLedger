<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:CampLedger.ViewModels"
             xmlns:pages="clr-namespace:CampLedger.Pages"
             xmlns:models="clr-namespace:CampLedger.Models"
             x:Class="CampLedger.Pages.InventoryPage"
             x:DataType="viewModels:InventoryViewModel"
             Title="Inventory"
             Style="{StaticResource PageStyle}">

    <Grid RowDefinitions="Auto,*" Padding="16" RowSpacing="16">
        <Border Padding="12" StrokeShape="RoundRectangle 16" BackgroundColor="{DynamicResource SurfaceColor}">
            <VerticalStackLayout Spacing="8">
               <Label Text="Search inventory" FontAttributes="Bold" FontSize="18" />
               <SearchBar x:Name="SearchBar" Placeholder="Search all items..." SearchCommand="{Binding SearchCommand}" SearchCommandParameter="{Binding Text, Source={x:Reference SearchBar}}" TextChanged="OnSearchTextChanged" />
               <Button Text="Clear" Clicked="OnClearSearchClicked" />
            </VerticalStackLayout>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="16">
               <Border Padding="12" StrokeShape="RoundRectangle 16" BackgroundColor="{DynamicResource SurfaceColor}">
                   <VerticalStackLayout Spacing="10">
                       <Label Text="Needs" FontAttributes="Bold" FontSize="20" TextColor="{DynamicResource PrimaryColor}" />
                       <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                           <Entry Grid.Column="0" Placeholder="Add a needed item" Text="{Binding NewNeedsItemName}" />
                           <Button Grid.Column="1" Text="Add" Command="{Binding AddNeedsItemCommand}" />
                       </Grid>
                       <CollectionView ItemsSource="{Binding NeedsItems}" SelectionMode="None" Margin="0,2,0,0" ItemSizingStrategy="MeasureFirstItem">
                           <CollectionView.ItemsLayout>
                               <GridItemsLayout Orientation="Vertical" Span="2" HorizontalItemSpacing="8" VerticalItemSpacing="8" />
                           </CollectionView.ItemsLayout>
                           <CollectionView.ItemTemplate>
                               <DataTemplate x:DataType="viewModels:InventoryItemViewModel">
                                   <Border Padding="8" StrokeThickness="0" StrokeShape="RoundRectangle 12" BackgroundColor="{DynamicResource SurfaceAltColor}">
                                       <Grid RowDefinitions="Auto,Auto" RowSpacing="6">
                                           <Label Text="{Binding Name}" VerticalOptions="Center" LineBreakMode="WordWrap" MaxLines="2" />
                                           <Button Grid.Row="1" Text="Remove" Clicked="OnRemoveItemClicked" BackgroundColor="{DynamicResource ErrorColor}" HeightRequest="36" FontSize="12" />
                                       </Grid>
                                   </Border>
                               </DataTemplate>
                           </CollectionView.ItemTemplate>
                       </CollectionView>
                   </VerticalStackLayout>
               </Border>

               <Border Padding="12" StrokeShape="RoundRectangle 16" BackgroundColor="{DynamicResource SurfaceColor}">
                   <VerticalStackLayout Spacing="10">
                       <Label Text="Wants" FontAttributes="Bold" FontSize="20" TextColor="{DynamicResource PrimaryColor}" />
                       <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                           <Entry Grid.Column="0" Placeholder="Add an optional item" Text="{Binding NewWantsItemName}" />
                           <Button Grid.Column="1" Text="Add" Command="{Binding AddWantsItemCommand}" />
                       </Grid>
                       <CollectionView ItemsSource="{Binding WantsItems}" SelectionMode="None" Margin="0,2,0,0" ItemSizingStrategy="MeasureFirstItem">
                           <CollectionView.ItemsLayout>
                               <GridItemsLayout Orientation="Vertical" Span="2" HorizontalItemSpacing="8" VerticalItemSpacing="8" />
                           </CollectionView.ItemsLayout>
                           <CollectionView.ItemTemplate>
                               <DataTemplate x:DataType="viewModels:InventoryItemViewModel">
                                   <Border Padding="8" StrokeThickness="0" StrokeShape="RoundRectangle 12" BackgroundColor="{DynamicResource SurfaceAltColor}">
                                       <Grid RowDefinitions="Auto,Auto" RowSpacing="6">
                                           <Label Text="{Binding Name}" VerticalOptions="Center" LineBreakMode="WordWrap" MaxLines="2" />
                                           <Button Grid.Row="1" Text="Remove" Clicked="OnRemoveItemClicked" BackgroundColor="{DynamicResource ErrorColor}" HeightRequest="36" FontSize="12" />
                                       </Grid>
                                   </Border>
                               </DataTemplate>
                           </CollectionView.ItemTemplate>
                       </CollectionView>
                   </VerticalStackLayout>
               </Border>

               <Border Padding="12" StrokeShape="RoundRectangle 16" BackgroundColor="{DynamicResource SurfaceColor}">
                   <VerticalStackLayout Spacing="10">
                       <Label Text="Has" FontAttributes="Bold" FontSize="20" TextColor="{DynamicResource PrimaryColor}" />
                       <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                           <Entry Grid.Column="0" Placeholder="Add an owned item" Text="{Binding NewHasItemName}" />
                           <Button Grid.Column="1" Text="Add" Command="{Binding AddHasItemCommand}" />
                       </Grid>
                       <CollectionView ItemsSource="{Binding HasItems}" SelectionMode="None" Margin="0,2,0,0" ItemSizingStrategy="MeasureFirstItem">
                           <CollectionView.ItemsLayout>
                               <GridItemsLayout Orientation="Vertical" Span="2" HorizontalItemSpacing="8" VerticalItemSpacing="8" />
                           </CollectionView.ItemsLayout>
                           <CollectionView.ItemTemplate>
                               <DataTemplate x:DataType="viewModels:InventoryItemViewModel">
                                   <Border Padding="8" StrokeThickness="0" StrokeShape="RoundRectangle 12" BackgroundColor="{DynamicResource SurfaceAltColor}">
                                       <Grid RowDefinitions="Auto,Auto" RowSpacing="6">
                                           <Label Text="{Binding Name}" VerticalOptions="Center" LineBreakMode="WordWrap" MaxLines="2" />
                                           <Button Grid.Row="1" Text="Remove" Clicked="OnRemoveItemClicked" BackgroundColor="{DynamicResource ErrorColor}" HeightRequest="36" FontSize="12" />
                                       </Grid>
                                   </Border>
                               </DataTemplate>
                           </CollectionView.ItemTemplate>
                       </CollectionView>
                   </VerticalStackLayout>
               </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
