<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:CampLedger.ViewModels"
             x:Class="CampLedger.Pages.TripHistoryPage"
             x:DataType="viewModels:TripHistoryViewModel"
             Title="Travel History"
              Style="{StaticResource PageStyle}">

    <Grid>
        <ScrollView IsVisible="{Binding IsListVisible}">
            <VerticalStackLayout Padding="16" Spacing="12">

                <Border Padding="12" BackgroundColor="{DynamicResource SurfaceColor}" StrokeThickness="2" Stroke="{DynamicResource BorderColor}" StrokeShape="RoundRectangle 16">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Filter by Date Range" FontAttributes="Bold" FontSize="16" TextColor="{DynamicResource PrimaryColor}" />
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" RowDefinitions="Auto,Auto" RowSpacing="6">
                            <Label Grid.Row="0" Grid.Column="0" Text="From:" VerticalOptions="Center" Style="{StaticResource EmphasisLabel}" />
                            <DatePicker Grid.Row="0" Grid.Column="1" Date="{Binding FilterStartDate}" />
                            <Label Grid.Row="1" Grid.Column="0" Text="To:" VerticalOptions="Center" Style="{StaticResource EmphasisLabel}" />
                            <DatePicker Grid.Row="1" Grid.Column="1" Date="{Binding FilterEndDate}" />
                        </Grid>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Button ImageSource="{FontImageSource Glyph={StaticResource IconFilter}, FontFamily={StaticResource IconFontFamily}, Size=20}" SemanticProperties.Description="Apply filter" Command="{Binding ApplyFilterCommand}" BackgroundColor="{DynamicResource PrimaryColor}" TextColor="White" />
                            <Button Grid.Column="1" ImageSource="{FontImageSource Glyph={StaticResource IconShowAll}, FontFamily={StaticResource IconFontFamily}, Size=20}" SemanticProperties.Description="Show all trips" Command="{Binding ClearFilterCommand}" BackgroundColor="{DynamicResource TertiaryTextColor}" TextColor="White" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Button ImageSource="{FontImageSource Glyph={StaticResource IconRefresh}, FontFamily={StaticResource IconFontFamily}, Size=20}" SemanticProperties.Description="Refresh trips" Command="{Binding RefreshCommand}" HorizontalOptions="Start" BackgroundColor="{DynamicResource PrimaryColor}" TextColor="White" />

                <CollectionView ItemsSource="{Binding FilteredTrips}" SelectionMode="None">
                    <CollectionView.EmptyView>
                        <Label Text="No trips found for the selected range." FontAttributes="Italic" TextColor="{DynamicResource TertiaryTextColor}" HorizontalTextAlignment="Center" VerticalOptions="Fill" />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:TripRecordViewModel">
                            <Border Padding="12" Margin="0,0,0,10" BackgroundColor="{DynamicResource SurfaceColor}" StrokeThickness="2" Stroke="{DynamicResource BorderColor}" StrokeShape="RoundRectangle 16">
                                <VerticalStackLayout Spacing="8">
                                    <Button ImageSource="{FontImageSource Glyph={StaticResource IconEdit}, FontFamily={StaticResource IconFontFamily}, Size=20}" SemanticProperties.Description="Edit trip"
                                            FontSize="12" 
                                            Padding="8,4"
                                            HorizontalOptions="Start"
                                            BackgroundColor="{DynamicResource PrimaryColor}" TextColor="White"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:TripHistoryViewModel}}, Path=BeginEditTripDetailsCommand}"
                                            CommandParameter="{Binding .}"
                                            IsVisible="{Binding IsNotEditingTripDetails}" />
                                    <Label Text="{Binding TripDurationText, StringFormat='Trip Duration: {0}'}" FontAttributes="Bold" FontSize="16" TextColor="{DynamicResource PrimaryColor}" IsVisible="{Binding IsNotEditingTripDetails}" />

                                    <VerticalStackLayout Spacing="8" IsVisible="{Binding IsEditingTripDetails}">
                                        <Label Text="Trip Duration:" FontAttributes="Bold" FontSize="16" TextColor="{DynamicResource PrimaryColor}" />
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" RowDefinitions="Auto,Auto" RowSpacing="6">
                                            <Label Grid.Row="0" Grid.Column="0" Text="Start:" VerticalOptions="Center" Style="{StaticResource EmphasisLabel}" />
                                            <DatePicker Grid.Row="0" Grid.Column="1" Date="{Binding EditingStartDate}" />
                                            <Label Grid.Row="1" Grid.Column="0" Text="End:" VerticalOptions="Center" Style="{StaticResource EmphasisLabel}" />
                                            <DatePicker Grid.Row="1" Grid.Column="1" Date="{Binding EditingEndDate}" MinimumDate="{Binding EditingStartDate}" />
                                        </Grid>
                                    </VerticalStackLayout>

                                    <!-- Location display and actions -->
                                    <!-- Only show the location button when not editing trip details -->
                                    <Button ImageSource="{FontImageSource Glyph={StaticResource IconLocation}, FontFamily={StaticResource IconFontFamily}, Size=20}" SemanticProperties.Description="Add location"
                                            IsVisible="{Binding IsNotEditingTripDetails}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:TripHistoryViewModel}}, Path=OpenOrEditLocationCommand}"
                                            CommandParameter="{Binding .}"
                                            IsEnabled="{Binding HasLocation}"
                                            BackgroundColor="{DynamicResource PrimaryColor}"
                                            TextColor="White"
                                            FontSize="12"
                                            Padding="8,4"
                                            HorizontalOptions="Start" />

                                    <!-- Editing location area: show current/editing location and horizontal buttons beneath the location button -->
                                    <VerticalStackLayout Spacing="6" IsVisible="{Binding IsEditingTripDetails}">
                                        <Label Text="{Binding EditingLocationText}" FontAttributes="Bold" FontSize="12" Style="{StaticResource EmphasisLabel}" VerticalOptions="Center" />
                                        <HorizontalStackLayout Spacing="8">
                                            <Button Text="Change Location"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:TripHistoryViewModel}}, Path=EditTripLocationCommand}"
                                                    CommandParameter="{Binding .}"
                                                    BackgroundColor="{DynamicResource PrimaryColor}"
                                                    TextColor="White"
                                                    FontSize="12"
                                                    Padding="8,4"
                                                    HorizontalOptions="Fill" />
                                            <Button ImageSource="{FontImageSource Glyph={StaticResource IconClear}, FontFamily={StaticResource IconFontFamily}, Size=20}" SemanticProperties.Description="Clear location"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:TripHistoryViewModel}}, Path=ClearEditingTripLocationCommand}"
                                                    CommandParameter="{Binding .}"
                                                    BackgroundColor="{DynamicResource TertiaryTextColor}"
                                                    TextColor="White"
                                                    FontSize="12"
                                                    Padding="8,4"
                                                    HorizontalOptions="Fill" />
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>

                                    <BoxView HeightRequest="1" BackgroundColor="{DynamicResource BorderColor}" />

                                    <Grid ColumnDefinitions="*" ColumnSpacing="8">
                                        <Label Grid.Column="0" Text="Notes:" Style="{StaticResource EmphasisLabel}" FontSize="12" VerticalOptions="Center" />

                                    </Grid>

                                    <Label Text="{Binding Notes}" FontSize="13" LineBreakMode="WordWrap" TextColor="{DynamicResource SecondaryTextColor}"
                                           IsVisible="{Binding IsNotEditingTripDetails}" />

                                    <!-- When editing trip details, notes become editable and are saved/cancelled as part of Save Trip / Cancel Edit -->
                                    <VerticalStackLayout Spacing="6" IsVisible="{Binding IsEditingTripDetails}">
                                        <Editor Text="{Binding EditingNotes}" TextChanged="OnEditorTextChanged" Placeholder="Enter trip notes..." AutoSize="TextChanges" MinimumHeightRequest="60" />

                                    </VerticalStackLayout>

                                 

                                    <!-- Editable checklist when editing trip details -->
                                    <VerticalStackLayout Spacing="6" IsVisible="{Binding IsEditingTripDetails}">
                                        <Label Text="Checklist:" FontAttributes="Bold" FontSize="12" Style="{StaticResource EmphasisLabel}" />
                                        <CollectionView ItemsSource="{Binding EditingChecklistItems}" SelectionMode="None" Margin="0,2,0,0" ItemSizingStrategy="MeasureFirstItem">
                                            <CollectionView.ItemsLayout>
                                                <GridItemsLayout Orientation="Vertical" Span="2" HorizontalItemSpacing="8" VerticalItemSpacing="8" />
                                            </CollectionView.ItemsLayout>
                                            <CollectionView.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="8" BackgroundColor="{DynamicResource SurfaceAltColor}" StrokeThickness="0" StrokeShape="RoundRectangle 10">
                                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                                            <CheckBox IsChecked="{Binding IsPacked}" VerticalOptions="Center" />
                                                            <Label Grid.Column="1" Text="{Binding Name}" VerticalOptions="Center" LineBreakMode="WordWrap" MaxLines="2" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </CollectionView.ItemTemplate>
                                        </CollectionView>
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="Summary:" FontAttributes="Bold" FontSize="12" Style="{StaticResource EmphasisLabel}" />
                                        <Label Text="{Binding PackedCount, StringFormat='✓ Packed: {0} items'}" FontSize="13" TextColor="{DynamicResource SuccessColor}" />
                                        <Label Text="{Binding ForgottenCount, StringFormat='✗ Forgotten: {0} items'}" FontSize="13" TextColor="{DynamicResource ErrorColor}" />
                                    </VerticalStackLayout>

                                    <Label Text="Packed:" FontAttributes="Bold" FontSize="12" TextColor="{DynamicResource SuccessColor}" />
                                    <Label Text="{Binding PackedItems}" FontSize="12" LineBreakMode="WordWrap" TextColor="{DynamicResource SecondaryTextColor}" />

                                    <Label Text="Forgotten:" FontAttributes="Bold" FontSize="12" TextColor="{DynamicResource ErrorColor}" />
                                    <Label Text="{Binding ForgottenItems}" FontSize="12" LineBreakMode="WordWrap" TextColor="{DynamicResource SecondaryTextColor}" />
                                    <VerticalStackLayout Spacing="6" IsVisible="{Binding IsEditingTripDetails}">
                                        <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="8">
                                            <Button Grid.Column="0" ImageSource="{FontImageSource Glyph={StaticResource IconSave}, FontFamily={StaticResource IconFontFamily}, Size=20}" SemanticProperties.Description="Save trip" BackgroundColor="{DynamicResource SuccessColor}" TextColor="White"
                                                   Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:TripHistoryViewModel}}, Path=SaveTripDetailsCommand}"
                                                   CommandParameter="{Binding .}" />
                                            <Button Grid.Column="1" Text="Delete Trip" BackgroundColor="{DynamicResource ErrorColor}" TextColor="White" Padding="8,4"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:TripHistoryViewModel}}, Path=DeleteTripCommand}"
                                                    CommandParameter="{Binding .}" />
                                            <Button Grid.Column="2" Text="Cancel Edit" BackgroundColor="{DynamicResource TertiaryTextColor}" TextColor="White"
                                                   Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:TripHistoryViewModel}}, Path=CancelEditTripDetailsCommand}"
                                                   CommandParameter="{Binding .}" />
                                        </Grid>
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Full-screen single-trip editor overlay -->
        <Grid BackgroundColor="{DynamicResource SurfaceColor}" IsVisible="{Binding IsEditingTripInFullScreen}" Padding="16">
            <ScrollView>
                <VerticalStackLayout BindingContext="{Binding EditingTrip}" x:DataType="viewModels:TripRecordViewModel" Spacing="12">
                    <Label Text="Edit Trip" FontAttributes="Bold" FontSize="20" TextColor="{DynamicResource PrimaryColor}" />

                    <Label Text="Trip Duration:" FontAttributes="Bold" FontSize="16" TextColor="{DynamicResource PrimaryColor}" />
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" RowDefinitions="Auto,Auto" RowSpacing="6">
                        <Label Grid.Row="0" Grid.Column="0" Text="Start:" VerticalOptions="Center" Style="{StaticResource EmphasisLabel}" />
                        <DatePicker Grid.Row="0" Grid.Column="1" Date="{Binding EditingStartDate}" />
                        <Label Grid.Row="1" Grid.Column="0" Text="End:" VerticalOptions="Center" Style="{StaticResource EmphasisLabel}" />
                        <DatePicker Grid.Row="1" Grid.Column="1" Date="{Binding EditingEndDate}" MinimumDate="{Binding EditingStartDate}" />
                    </Grid>

                    <Label Text="Notes:" FontAttributes="Bold" FontSize="14" Style="{StaticResource EmphasisLabel}" />
                    <Editor Text="{Binding EditingNotes}" AutoSize="TextChanges" MinimumHeightRequest="120" />

                    <Label Text="Location:" FontAttributes="Bold" FontSize="14" Style="{StaticResource EmphasisLabel}" />
                    <Label Text="{Binding EditingLocationText}" />
                    <HorizontalStackLayout Spacing="8">
                        <Button Text="Change Location"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:TripHistoryViewModel}}, Path=EditTripLocationCommand}"
                                CommandParameter="{Binding .}"
                                BackgroundColor="{DynamicResource PrimaryColor}"
                                TextColor="White" />
                        <Button ImageSource="{FontImageSource Glyph={StaticResource IconClear}, FontFamily={StaticResource IconFontFamily}, Size=20}" SemanticProperties.Description="Clear location"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:TripHistoryViewModel}}, Path=ClearEditingTripLocationCommand}"
                                CommandParameter="{Binding .}"
                                BackgroundColor="{DynamicResource TertiaryTextColor}"
                                TextColor="White" />
                    </HorizontalStackLayout>

                    <Label Text="Checklist:" FontAttributes="Bold" FontSize="14" Style="{StaticResource EmphasisLabel}" />
                    <CollectionView ItemsSource="{Binding EditingChecklistItems}" SelectionMode="None" Margin="0,2,0,0" ItemSizingStrategy="MeasureFirstItem">
                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical" Span="2" HorizontalItemSpacing="8" VerticalItemSpacing="8" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8" BackgroundColor="{DynamicResource SurfaceAltColor}" StrokeThickness="0" StrokeShape="RoundRectangle 10">
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                        <CheckBox IsChecked="{Binding IsPacked}" VerticalOptions="Center" />
                                        <Label Grid.Column="1" Text="{Binding Name}" VerticalOptions="Center" LineBreakMode="WordWrap" MaxLines="2" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="8">
                        <Button ImageSource="{FontImageSource Glyph={StaticResource IconSave}, FontFamily={StaticResource IconFontFamily}, Size=20}" SemanticProperties.Description="Save trip" BackgroundColor="{DynamicResource SuccessColor}" TextColor="White"
                               Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:TripHistoryViewModel}}, Path=SaveTripDetailsCommand}"
                               CommandParameter="{Binding .}" />
                        <Button Grid.Column="1" Text="Delete Trip" BackgroundColor="{DynamicResource ErrorColor}" TextColor="White"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:TripHistoryViewModel}}, Path=DeleteTripCommand}"
                                CommandParameter="{Binding .}" />
                        <Button Grid.Column="2" Text="Cancel Edit" BackgroundColor="{DynamicResource TertiaryTextColor}" TextColor="White"
                               Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:TripHistoryViewModel}}, Path=CancelEditTripDetailsCommand}"
                               CommandParameter="{Binding .}" />
                    </Grid>
                </VerticalStackLayout>
            </ScrollView>
        </Grid>

    </Grid>

</ContentPage>
