<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:CampLedger.ViewModels"
             x:Class="CampLedger.Pages.TripHistoryPage"
             x:DataType="viewModels:TripHistoryViewModel"
             Title="Trip History"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark={StaticResource Gray900}}">

    <Grid>
        <ScrollView IsVisible="{Binding IsListVisible}">
            <VerticalStackLayout Padding="16" Spacing="12">

                <Border Padding="12" BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}" StrokeThickness="2" Stroke="{StaticResource PrimaryLight}" StrokeShape="RoundRectangle 16">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Filter by Date Range" FontAttributes="Bold" FontSize="16" TextColor="{StaticResource Primary}" />
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" RowDefinitions="Auto,Auto" RowSpacing="6">
                            <Label Grid.Row="0" Grid.Column="0" Text="From:" VerticalOptions="Center" Style="{StaticResource EmphasisLabel}" />
                            <DatePicker Grid.Row="0" Grid.Column="1" Date="{Binding FilterStartDate}" />
                            <Label Grid.Row="1" Grid.Column="0" Text="To:" VerticalOptions="Center" Style="{StaticResource EmphasisLabel}" />
                            <DatePicker Grid.Row="1" Grid.Column="1" Date="{Binding FilterEndDate}" />
                        </Grid>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Button Text="Apply Filter" Command="{Binding ApplyFilterCommand}" BackgroundColor="{StaticResource Primary}" TextColor="{StaticResource White}" />
                            <Button Grid.Column="1" Text="Show All" Command="{Binding ClearFilterCommand}" BackgroundColor="{StaticResource Gray400}" TextColor="{StaticResource White}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Button Text="Refresh" Command="{Binding RefreshCommand}" HorizontalOptions="Start" BackgroundColor="{StaticResource Primary}" TextColor="{StaticResource White}" />

                <CollectionView ItemsSource="{Binding FilteredTrips}" SelectionMode="None">
                    <CollectionView.EmptyView>
                        <Label Text="No trips found for the selected range." FontAttributes="Italic" TextColor="{StaticResource Gray500}" HorizontalTextAlignment="Center" VerticalOptions="FillAndExpand" />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:TripRecordViewModel">
                            <Border Padding="12" Margin="0,0,0,10" BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}" StrokeThickness="2" Stroke="{StaticResource PrimaryLight}" StrokeShape="RoundRectangle 16">
                                <VerticalStackLayout Spacing="8">
                                    <Button Text="Edit" 
                                            FontSize="12" 
                                            Padding="8,4"
                                            HorizontalOptions="Start"
                                            BackgroundColor="{StaticResource Primary}" TextColor="{StaticResource White}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:TripHistoryViewModel}}, Path=BeginEditTripDetailsCommand}"
                                            CommandParameter="{Binding .}"
                                            IsVisible="{Binding IsNotEditingTripDetails}" />
                                    <Label Text="{Binding TripDurationText, StringFormat='Trip Duration: {0}'}" FontAttributes="Bold" FontSize="16" TextColor="{StaticResource Primary}" IsVisible="{Binding IsNotEditingTripDetails}" />

                                    <VerticalStackLayout Spacing="8" IsVisible="{Binding IsEditingTripDetails}">
                                        <Label Text="Trip Duration:" FontAttributes="Bold" FontSize="16" TextColor="{StaticResource Primary}" />
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" RowDefinitions="Auto,Auto" RowSpacing="6">
                                            <Label Grid.Row="0" Grid.Column="0" Text="Start:" VerticalOptions="Center" Style="{StaticResource EmphasisLabel}" />
                                            <DatePicker Grid.Row="0" Grid.Column="1" Date="{Binding EditingStartDate}" />
                                            <Label Grid.Row="1" Grid.Column="0" Text="End:" VerticalOptions="Center" Style="{StaticResource EmphasisLabel}" />
                                            <DatePicker Grid.Row="1" Grid.Column="1" Date="{Binding EditingEndDate}" MinimumDate="{Binding EditingStartDate}" />
                                        </Grid>
                                    </VerticalStackLayout>

                                    <!-- Location display and actions -->
                                    <!-- Only show the location button when not editing trip details -->
                                    <Button Text="{Binding LocationButtonText}"
                                            IsVisible="{Binding IsNotEditingTripDetails}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:TripHistoryViewModel}}, Path=OpenOrEditLocationCommand}"
                                            CommandParameter="{Binding .}"
                                            IsEnabled="{Binding HasLocation}"
                                            BackgroundColor="{StaticResource Primary}"
                                            TextColor="{StaticResource White}"
                                            FontSize="12"
                                            Padding="8,4"
                                            HorizontalOptions="Start" />

                                    <!-- Editing location area: show current/editing location and horizontal buttons beneath the location button -->
                                    <VerticalStackLayout Spacing="6" IsVisible="{Binding IsEditingTripDetails}">
                                        <Label Text="{Binding EditingLocationText}" FontAttributes="Bold" FontSize="12" Style="{StaticResource EmphasisLabel}" VerticalOptions="Center" />
                                        <HorizontalStackLayout Spacing="8">
                                            <Button Text="Change Location"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:TripHistoryViewModel}}, Path=EditTripLocationCommand}"
                                                    CommandParameter="{Binding .}"
                                                    BackgroundColor="{StaticResource Primary}"
                                                    TextColor="{StaticResource White}"
                                                    FontSize="12"
                                                    Padding="8,4"
                                                    HorizontalOptions="FillAndExpand" />
                                            <Button Text="Clear"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:TripHistoryViewModel}}, Path=ClearEditingTripLocationCommand}"
                                                    CommandParameter="{Binding .}"
                                                    BackgroundColor="{StaticResource Gray400}"
                                                    TextColor="{StaticResource White}"
                                                    FontSize="12"
                                                    Padding="8,4"
                                                    HorizontalOptions="FillAndExpand" />
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>

                                    <BoxView HeightRequest="1" BackgroundColor="{StaticResource PrimaryLight}" />

                                    <Grid ColumnDefinitions="*" ColumnSpacing="8">
                                        <Label Grid.Column="0" Text="Notes:" Style="{StaticResource EmphasisLabel}" FontSize="12" VerticalOptions="Center" />

                                    </Grid>

                                    <Label Text="{Binding Notes}" FontSize="13" LineBreakMode="WordWrap" TextColor="{StaticResource Gray600}"
                                           IsVisible="{Binding IsNotEditingTripDetails}" />

                                    <!-- When editing trip details, notes become editable and are saved/cancelled as part of Save Trip / Cancel Edit -->
                                    <VerticalStackLayout Spacing="6" IsVisible="{Binding IsEditingTripDetails}">
                                        <Editor Text="{Binding EditingNotes}" TextChanged="OnEditorTextChanged" Placeholder="Enter trip notes..." AutoSize="TextChanges" MinimumHeightRequest="60" />

                                    </VerticalStackLayout>

                                 

                                    <!-- Editable checklist when editing trip details -->
                                    <VerticalStackLayout Spacing="6" IsVisible="{Binding IsEditingTripDetails}">
                                        <Label Text="Checklist:" FontAttributes="Bold" FontSize="12" Style="{StaticResource EmphasisLabel}" />
                                        <CollectionView ItemsSource="{Binding EditingChecklistItems}" SelectionMode="None">
                                            <CollectionView.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" Padding="0,4">
                                                        <CheckBox IsChecked="{Binding IsPacked}" VerticalOptions="Center" />
                                                        <Label Grid.Column="1" Text="{Binding Name}" VerticalOptions="Center" />
                                                    </Grid>
                                                </DataTemplate>
                                            </CollectionView.ItemTemplate>
                                        </CollectionView>
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="Summary:" FontAttributes="Bold" FontSize="12" Style="{StaticResource EmphasisLabel}" />
                                        <Label Text="{Binding PackedCount, StringFormat='✓ Packed: {0} items'}" FontSize="13" TextColor="{StaticResource Success}" />
                                        <Label Text="{Binding ForgottenCount, StringFormat='✗ Forgotten: {0} items'}" FontSize="13" TextColor="{StaticResource Danger}" />
                                    </VerticalStackLayout>

                                    <Label Text="Packed:" FontAttributes="Bold" FontSize="12" TextColor="{StaticResource Success}" />
                                    <Label Text="{Binding PackedItems}" FontSize="12" LineBreakMode="WordWrap" TextColor="{StaticResource Gray600}" />

                                    <Label Text="Forgotten:" FontAttributes="Bold" FontSize="12" TextColor="{StaticResource Danger}" />
                                    <Label Text="{Binding ForgottenItems}" FontSize="12" LineBreakMode="WordWrap" TextColor="{StaticResource Gray600}" />
                                    <VerticalStackLayout Spacing="6" IsVisible="{Binding IsEditingTripDetails}">
                                        <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="8">
                                            <Button Grid.Column="0" Text="Save Trip" BackgroundColor="{StaticResource Success}" TextColor="{StaticResource White}"
                                                   Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:TripHistoryViewModel}}, Path=SaveTripDetailsCommand}"
                                                   CommandParameter="{Binding .}" />
                                            <Button Grid.Column="1" Text="Delete Trip" BackgroundColor="{StaticResource Danger}" TextColor="{StaticResource White}" Padding="8,4"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:TripHistoryViewModel}}, Path=DeleteTripCommand}"
                                                    CommandParameter="{Binding .}" />
                                            <Button Grid.Column="2" Text="Cancel Edit" BackgroundColor="{StaticResource Gray400}" TextColor="{StaticResource White}"
                                                   Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:TripHistoryViewModel}}, Path=CancelEditTripDetailsCommand}"
                                                   CommandParameter="{Binding .}" />
                                        </Grid>
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Spacing="6" IsVisible="{Binding HasPhotoItems}">
                                        <Label Text="Item Photos:" FontAttributes="Bold" FontSize="12" Style="{StaticResource EmphasisLabel}" />
                                        <CollectionView ItemsSource="{Binding PhotoItems}" SelectionMode="None">
                                            <CollectionView.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="8" Margin="0,2" BackgroundColor="{StaticResource PrimaryPale}" StrokeThickness="0" StrokeShape="RoundRectangle 10">
                                                        <VerticalStackLayout Spacing="4">
                                                            <Label Text="{Binding Name}" FontSize="12" FontAttributes="Bold" Style="{StaticResource EmphasisLabel}" />
                                                            <Image Source="{Binding PhotoSource}" Aspect="AspectFit" HeightRequest="150" WidthRequest="150" HorizontalOptions="Start">
                                                                <Image.GestureRecognizers>
                                                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:TripHistoryViewModel}}, Path=OpenPhotoPreviewCommand}" CommandParameter="{Binding .}" />
                                                                </Image.GestureRecognizers>
                                                            </Image>
                                                        </VerticalStackLayout>
                                                    </Border>
                                                </DataTemplate>
                                            </CollectionView.ItemTemplate>
                                        </CollectionView>
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Full-screen single-trip editor overlay -->
        <Grid BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}" IsVisible="{Binding IsEditingTripInFullScreen}" Padding="16">
            <ScrollView>
                <VerticalStackLayout BindingContext="{Binding EditingTrip}" x:DataType="viewModels:TripRecordViewModel" Spacing="12">
                    <Label Text="Edit Trip" FontAttributes="Bold" FontSize="20" TextColor="{StaticResource Primary}" />

                    <Label Text="Trip Duration:" FontAttributes="Bold" FontSize="16" TextColor="{StaticResource Primary}" />
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" RowDefinitions="Auto,Auto" RowSpacing="6">
                        <Label Grid.Row="0" Grid.Column="0" Text="Start:" VerticalOptions="Center" Style="{StaticResource EmphasisLabel}" />
                        <DatePicker Grid.Row="0" Grid.Column="1" Date="{Binding EditingStartDate}" />
                        <Label Grid.Row="1" Grid.Column="0" Text="End:" VerticalOptions="Center" Style="{StaticResource EmphasisLabel}" />
                        <DatePicker Grid.Row="1" Grid.Column="1" Date="{Binding EditingEndDate}" MinimumDate="{Binding EditingStartDate}" />
                    </Grid>

                    <Label Text="Notes:" FontAttributes="Bold" FontSize="14" Style="{StaticResource EmphasisLabel}" />
                    <Editor Text="{Binding EditingNotes}" AutoSize="TextChanges" MinimumHeightRequest="120" />

                    <Label Text="Location:" FontAttributes="Bold" FontSize="14" Style="{StaticResource EmphasisLabel}" />
                    <Label Text="{Binding EditingLocationText}" />
                    <HorizontalStackLayout Spacing="8">
                        <Button Text="Change Location"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:TripHistoryViewModel}}, Path=EditTripLocationCommand}"
                                CommandParameter="{Binding .}"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="{StaticResource White}" />
                        <Button Text="Clear"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:TripHistoryViewModel}}, Path=ClearEditingTripLocationCommand}"
                                CommandParameter="{Binding .}"
                                BackgroundColor="{StaticResource Gray400}"
                                TextColor="{StaticResource White}" />
                    </HorizontalStackLayout>

                    <Label Text="Checklist:" FontAttributes="Bold" FontSize="14" Style="{StaticResource EmphasisLabel}" />
                    <CollectionView ItemsSource="{Binding EditingChecklistItems}" SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" Padding="0,4">
                                    <CheckBox IsChecked="{Binding IsPacked}" VerticalOptions="Center" />
                                    <Label Grid.Column="1" Text="{Binding Name}" VerticalOptions="Center" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="8">
                        <Button Text="Save Trip" BackgroundColor="{StaticResource Success}" TextColor="{StaticResource White}"
                               Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:TripHistoryViewModel}}, Path=SaveTripDetailsCommand}"
                               CommandParameter="{Binding .}" />
                        <Button Grid.Column="1" Text="Delete Trip" BackgroundColor="{StaticResource Danger}" TextColor="{StaticResource White}"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:TripHistoryViewModel}}, Path=DeleteTripCommand}"
                                CommandParameter="{Binding .}" />
                        <Button Grid.Column="2" Text="Cancel Edit" BackgroundColor="{StaticResource Gray400}" TextColor="{StaticResource White}"
                               Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:TripHistoryViewModel}}, Path=CancelEditTripDetailsCommand}"
                               CommandParameter="{Binding .}" />
                    </Grid>
                </VerticalStackLayout>
            </ScrollView>
        </Grid>

        <Grid BackgroundColor="#CC000000" IsVisible="{Binding IsPhotoPreviewVisible}" Padding="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Button Grid.Row="0" Text="Close" Command="{Binding ClosePhotoPreviewCommand}" BackgroundColor="{StaticResource Gray500}" TextColor="{StaticResource White}" HorizontalOptions="End" />
            <Border Grid.Row="1" Padding="8" BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}" StrokeThickness="0" StrokeShape="RoundRectangle 12" VerticalOptions="Center" HorizontalOptions="Center">
                <Image Source="{Binding PhotoPreviewSource}" Aspect="AspectFit" HeightRequest="500" WidthRequest="500" />
            </Border>
        </Grid>
    </Grid>

</ContentPage>
